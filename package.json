{
    "name": "memoire-collective",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "pnpm --recursive run build",
        "update": "ncu -u --deep",
        "sort-package": "pnpm --recursive --parallel exec sort-package-json package.json"
    },
    "devDependencies": {
        "npm-check-updates": "^19.3.2",
        "sort-package-json": "^3.6.1"
    },
    "pnpm": {
        "overrides": {
            "vite": "npm:rolldown-vite@7.3.1"
        },
        "onlyBuiltDependencies": [
            "esbuild",
            "unrs-resolver",
            "vue-demi"
        ]
    }
}
